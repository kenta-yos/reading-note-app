datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

enum BookStatus {
  WANT_TO_READ
  READING_STACK
  READING
  READ
}

model Book {
  id            String        @id @default(cuid())
  title         String
  author        String?
  publisher     String?
  publishedYear Int?
  isbn          String?
  pages         Int?
  category      String?
  discipline    String?
  rating        Int?
  description   String?
  notes         String?
  status          BookStatus    @default(READ)
  readAt          DateTime?
  statusChangedAt DateTime      @default(now())
  createdAt       DateTime      @default(now())
  keywords      BookKeyword[]
  memos         ReadingMemo[]

  @@index([status])
  @@index([readAt])
  @@index([category])
  @@index([status, readAt])
}

model ReadingMemo {
  id        String   @id @default(cuid())
  bookId    String
  content   String
  quote     String?
  page      Int?
  createdAt DateTime @default(now())
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([createdAt])
}

model BookKeyword {
  id      String @id @default(cuid())
  bookId  String
  keyword String
  count   Int    @default(1)
  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, keyword])
  @@index([keyword])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model AnnualGoal {
  id        String   @id @default(cuid())
  year      Int      @unique
  pageGoal  Int
  createdAt DateTime @default(now())
}

model WatchPublisher {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model DiscoverBookmark {
  id         String   @id @default(cuid())
  isbn       String   @unique
  title      String
  author     String?
  publisher  String?
  issued     String
  ndcCode    String?
  discipline String?
  ndlUrl     String?
  createdAt  DateTime @default(now())
}

model ReadingInsight {
  id        String   @id @default(cuid())
  analysis  Json     // { discoveries: [...], evolution: [...] }
  bookCount Int
  createdAt DateTime @default(now())
}

model RecommendSession {
  id              String   @id @default(cuid())
  recommendations Json     // Recommendation[]
  searchType      String   @default("auto")
  userQuery       String?
  createdAt       DateTime @default(now())
}

model DiscoveredBook {
  id          String   @id @default(cuid())
  isbn        String   @unique
  title       String
  author      String?
  publisher   String?
  issued      String
  price       Int?
  ndcCode     String?
  discipline  String?
  ndlUrl      String?
  firstSeenAt DateTime @default(now())
}
